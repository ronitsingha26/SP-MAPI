+exports.superExport = async (req, res, next) => {
+  try {
+    const { jsonToCsv } = require('../utils/csvExport');
+    const type = req.params.type;
+    let data = [];
+    if (type === 'payments') {
+      const result = await adminService.getAllPayments({ limit: 10000, page: 1 }, req.user);
+      data = result.payments || result || [];
+    } else if (type === 'users') {
+      const usersData = await adminService.getAllUsers({ limit: 10000, page: 1, type: 'customers' });
+      data = usersData.users || [];
+    } else {
+      return next(new (require('../middleware/errorHandler').AppError)('Invalid export type', 400));
+    }
+    const csv = jsonToCsv(data);
+    res.header('Content-Type', 'text/csv');
+    res.attachment(`${type}_export_${Date.now()}.csv`);
+    res.send(csv);
+  } catch (err) { next(err); }
+};
